# PaperScope 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ==================== API 配置 ====================
# OpenAI API 配置
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4

# Bocha Search API 配置（用于网络搜索工具）
BOCHA_API_KEY=your_bocha_api_key_here
BOCHA_API_URL=https://api.bocha.cn/search

# ==================== 模型路径配置 ====================
# vLLM 本地模型路径
VLLM_MODEL_PATH=Qwen/Qwen3-32B
MODEL_PATH=Qwen/WebWatcher-32B

# OCR 模型路径
OCR_MODEL_PATH=deepseek-ai/DeepSeek-OCR

# 多模态嵌入模型路径
EMBEDDING_MODEL_PATH=opensearch-ai/Ops-MM-embedding-v1-2B

# MinerU 文档解析模型路径
MINERU_MODEL_PATH=MinerU2.5-2509-1.2B

# ==================== GPU 配置 ====================
CUDA_VISIBLE_DEVICES=0

# ==================== 数据路径配置 ====================
# 数据根目录
DATA_ROOT=./data

# 输出根目录
OUTPUT_ROOT=./data/organized_papers

# PDF 文件基础目录
PDF_BASE_DIR=./data/papers

# 文档语料库路径（用于 FileSearchTool）
CORPUS_PATH=./doc_parse/output

# ==================== 评估配置 ====================
# 评估结果目录
RESULTS_DIR=./eval/src/results

# 知识文件路径（用于 solution 评估）
KNOWLEDGE_FILE=./qa_constructor/solution_data_constructor/results/solution_knowledge.jsonl

# 评估输出文件
OUTPUT_FILE=./eval/src/evaluation_results.json

# QA 数据文件路径
QA_FILE_PATH=./qa_constructor/reasoning_data_constructor/results/reasoning_questions.jsonl

# 文档基础路径
DOCS_BASE_PATH=./doc_parse/output

# ==================== 其他配置 ====================
# 论文查找 JSONL 文件路径
LOOKUP_JSONL_PATH=./paper_process/paper_map/paper_map.jsonl

# 选定论文结果路径
SELECTED_PAPERS_PATH=./output/selected_papers/results.jsonl

# 每次运行的最大 LLM 调用次数
MAX_LLM_CALL_PER_RUN=100

